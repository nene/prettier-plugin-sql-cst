{
  "compilerOptions": {
    "types": ["node", "jest"],
    "target": "es2022",
    "paths": { "src/*": ["./src/*"] },
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true
  },
  "include": ["src", "tsconfig.json", "test"]
}
